{
    "compilerOptions": {
        "outDir": "./dist/",
        "noImplicitAny": true,
        "module": "ESNext",
        "target": "ES2020",
        "jsx": "react",
        "allowJs": true,
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "baseUrl": "./",
        "types": [
            "element-plus/global"
        ],
        "paths": {
            "@": [
                "src"
            ],
            "@/*": [
                "src/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "typings/*"
    ],
    "exclude": [
        "node_modules"
    ]
}